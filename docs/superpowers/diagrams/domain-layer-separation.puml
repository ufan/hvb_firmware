@startuml
title Register-Catalog Layer Separation

rectangle "Frontend Adapters" {
  component "Modbus View" as modbus
  component "Shell" as shell
  component "Future UI / Protocol" as future
}

component "Register Catalog\nstatic iterable descriptors" as catalog

rectangle "State Owners" {
  component "VC Runtime Owner" as vc
  component "System Status Owner" as sys
  component "Modbus Adapter Owner" as mbowner
}

database "VC Canonical State" as vcstate
database "Atomic System Telemetry" as sysstate
database "Active + Next-Boot Modbus Config" as mbstate

modbus --> catalog : descriptor handles
shell --> catalog : semantic IDs
future --> catalog : generated view
catalog --> vc : owner callback
catalog --> sys : owner callback
catalog --> mbowner : owner callback
vc --> vcstate
sys --> sysstate
mbowner --> mbstate
@enduml
