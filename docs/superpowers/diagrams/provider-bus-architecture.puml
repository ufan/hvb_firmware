@startuml
title Virtual Channel Provider and Canonical State

rectangle "Static Build Composition" {
  component "Devicetree VC Channels" as dt
  component "Iterable Measurement Buffers" as buffers
  component "Iterable Register Descriptors" as descriptors
}

component "Virtual Channel Providers" as providers
component "VC Runtime Worker" as worker
database "VC Controller + Channel Canonical State" as state
component "Register Catalog" as catalog
component "Frontend Views" as frontends

dt --> providers
dt --> buffers
dt --> descriptors
providers --> buffers : publish raw evidence
buffers --> worker : wake + synchronized read
worker --> state : policy mutation
descriptors --> catalog
catalog --> state : owner-mediated scalar access
frontends --> catalog
@enduml
