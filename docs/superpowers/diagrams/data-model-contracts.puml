@startuml
title Register Catalog Contracts

class reg_id_t {
  module : uint8_t
  instance : uint8_t
  field : uint16_t
}

class reg_descriptor {
  id : reg_id_t
  type : reg_type
  access : reg_access
  category : reg_category
  value : void*
  owner : reg_owner*
}

interface reg_owner {
  read(descriptor, value) : reg_status
  write(descriptor, value, timeout) : reg_status
}

class reg_handle_t <<const pointer>>
class reg_value <<typed scalar>>
class PresentationSnapshot <<temporary>>

reg_descriptor *-- reg_id_t
reg_descriptor --> reg_owner
reg_handle_t --> reg_descriptor
reg_owner --> reg_value
PresentationSnapshot ..> reg_handle_t : assembled on demand
@enduml
