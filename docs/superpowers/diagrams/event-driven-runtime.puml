@startuml
title Register Read and Worker-Serialized Write

participant "Frontend" as frontend
participant "Register Catalog" as catalog
participant "VC Owner" as owner
queue "VC Command Queue" as queue
participant "VC Worker" as worker
database "Canonical State" as state

== Scalar read ==
frontend -> catalog : reg_handle_read() / reg_read()
catalog -> owner : read(descriptor)
owner -> state : lock + read one field
state --> owner : value
owner --> frontend : reg_status + value

== Mutation ==
frontend -> catalog : reg_handle_write() / reg_write()
catalog -> owner : write(descriptor, value)
owner -> queue : enqueue command
worker -> queue : dequeue
worker -> state : lock + validate + mutate
state --> worker : result
worker --> owner : completion semaphore
owner --> frontend : reg_status
@enduml
