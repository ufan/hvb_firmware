@startuml
!theme plain
title Factory Calibration Sequence — Jianwei Voltage-Control Board

actor "Technician" as T
participant "Shell\n(vc shell)" as SH
participant "Domain Runtime\n(vc_controller)" as CTRL
participant "Channel\n(vc_channel)" as CH
participant "DAC/ADC\n(Hardware)" as HW
database "NVS\n(Flash)" as NVS

== 1. Enter Calibration Mode ==

T -> SH : vc cal unlock
SH -> CTRL : vc_cmd_cal_unlock(0xCA1B)
CTRL -> CTRL : cal_unlock_step = 1
SH -> CTRL : vc_cmd_cal_unlock(0xA11B)
CTRL -> CTRL : cal_unlocked = true
SH --> T : calibration unlocked

T -> SH : vc mode cal
SH -> CTRL : set_operating_mode(CAL)
CTRL -> CTRL : save pre_cal_mode\nreset cal_watchdog (30s)
CTRL -> CH : reset_calibration(entering=true)
CH -> CH : state=CALIBRATION_OUTPUT\noutput_enabled=0, cal_output=0
CH -> HW : set_enable(false), set_output(0)
CTRL --> SH : VC_OK
SH --> T : OK

== 2. Per-Channel Calibration ==

T -> SH : vc cal max_dac <ch> <limit>
SH -> CTRL : cal_max_raw_dac(ch, limit)
CTRL -> CH : cal_set_max_raw_dac(limit)
SH --> T : OK

T -> SH : vc cal output <ch> on
SH -> CTRL : cal_output_enable(ch, true)
CTRL -> CTRL : cross-channel check\n(only 1 channel active)
CTRL -> CH : cal_set_output_enable(true)
CH -> CH : cal_output_enabled = 1
CH -> HW : set_enable(true), set_output(0)
SH --> T : OK

== For each calibration point ==

T -> SH : vc cal dac <ch> <code>
SH -> CTRL : cal_raw_dac(ch, code)
CTRL -> CH : cal_set_raw_dac(code)
CH -> CH : validate code <= max_limit\ncheck cal_output_enabled
CH -> HW : set_output(code)
SH --> T : OK

T -> SH : vc cal sample <ch>
SH -> CTRL : cal_sample(ch)
CTRL -> CH : cal_sample()
CH -> CH : raw_adc_voltage = raw_dac_readback\ncal_sample_status = VALID
SH --> T : OK
note right T : External factory tool reads\nraw ADC via Modbus registers\n(CH_RAW_ADC_VOLTAGE_HI/LO\n CH_RAW_ADC_CURRENT_HI/LO)

== Set Calibration Coefficients ==

T -> SH : vc cal set <ch> <field> <v>
SH -> CTRL : set_cal_field(ch, field, v)
CTRL -> CH : set_cal_field(field, v)
CH -> CH : update cal_config.k / .b
SH --> T : OK

T -> SH : vc cal config <ch>
SH --> T : "out_cal: k=X b=Y\n v_cal: k=X b=Y\n i_cal: k=X b=Y"

== 3. Disable + Commit ==

T -> SH : vc cal output <ch> off
SH -> CTRL : cal_output_enable(ch, false)
CTRL -> CH : cal_set_output_enable(false)
CH -> CH : cal_output_enabled = 0\nraw_dac_readback = 0
CH -> HW : set_output(0), set_enable(false)
SH --> T : OK

T -> SH : vc cal commit <ch>
SH -> CTRL : cal_commit(ch)
CTRL -> CH : cal_commit()
CH -> CH : verify: !cal_output_enabled\n&& raw_dac == 0
CTRL -> NVS : save_channel_cal(ch, cal_config)
SH --> T : OK (persisted)

== 4. Exit Calibration Mode ==

T -> SH : vc mode normal
SH -> CTRL : set_operating_mode(NORMAL)
CTRL -> CH : reset_calibration(entering=false)
CH -> CH : state=DISABLED_SAFE
CH -> HW : set_output(0), set_enable(false)
CTRL -> CTRL : cal_unlocked = false\ncal_unlock_step = 0
SH --> T : OK (normal mode)

@enduml
