config UI_MODBUS_RTU
	bool "Modbus RTU UI adapter"
	default n
	depends on MODBUS && VC_RUNTIME && VC_CHANNEL_CONTROLLER
	select REBOOT
	select SYS_RESET
	help
	  Enable Modbus RTU as the user interface adapter for the
	  voltage-control system.

if UI_MODBUS_RTU

config VC_MODBUS_UNIT_ID
	int "Modbus server unit ID"
	default 1
	range 1 247
	help
	  Modbus RTU slave address for the voltage-control server.

config VC_MODBUS_BAUD_RATE
	int "Modbus baud rate"
	default 115200
	help
	  Baud rate for the Modbus RTU serial interface.

config MODBUS_ADAPTER_SHELL
	bool "Shell commands for Modbus adapter"
	default n
	select SHELL
	help
	  Enable "mb" shell command tree for Modbus slave address
	  and baud rate configuration.

endif # UI_MODBUS_RTU
