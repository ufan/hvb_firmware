config VC_VARIANT_ID
	int "Voltage-control variant identifier reported over Modbus"
	default 1
	range 1 255
	help
	  Numeric identifier for the hardware variant (1 = HVB, 2 = LVB).
	  Reported in the VARIANT_ID Modbus register so host tools can adapt
	  their behaviour to the connected board type.

config VC_CHANNEL_CONTROLLER
	bool "VC channel controller DTS aggregation"
	default y
	depends on DT_HAS_JIANWEI_VC_CONTROLLER_ENABLED
	help
	  Enable compile-time channel construction from the
	  jianwei,vc-controller DTS node.

config VC_RUNTIME
	bool "VC runtime service"
	select SMF
	help
	  Enable the voltage-control runtime service.

config VC_RUNTIME_COMMAND_QUEUE_DEPTH
	int "VC runtime command queue depth"
	default 8
	range 1 64
	depends on VC_RUNTIME
	help
	  Maximum number of queued runtime commands.

config VC_RUNTIME_THREAD_STACK_SIZE
	int "VC runtime worker stack size"
	default 2048
	range 1024 8192
	depends on VC_RUNTIME
	help
	  Stack size in bytes for the voltage-control runtime worker.

config VC_RUNTIME_THREAD_PRIORITY
	int "VC runtime worker priority"
	default 5
	range 1 15
	depends on VC_RUNTIME
	help
	  Zephyr thread priority for the voltage-control runtime worker.

config VC_RUNTIME_TICK_INTERVAL_MS
	int "VC runtime policy tick interval"
	default 100
	range 1 60000
	depends on VC_RUNTIME
	help
	  Runtime policy tick interval in milliseconds.

config VC_CAL_SAMPLE_TIMEOUT_MS
	int "VC calibration sample freshness timeout"
	default 1000
	range 1 60000
	depends on VC_RUNTIME
	help
	  Upper bound in milliseconds for "vc cal sample" to wait for a
	  measurement newer than the one already cached, so the reported
	  raw ADC value reflects the DAC code just written rather than a
	  stale reading from before it. Must comfortably exceed the
	  hardware's worst-case conversion cycle. If no fresher sample
	  arrives within this window, the latest available reading is
	  returned anyway.

config VC_CAL_MAX_RAW_DAC
	int "Calibration DAC ceiling (raw counts)"
	default 65535
	range 1 65535
	help
	  Absolute upper bound for the calibration DAC code, set by the hardware
	  DAC resolution. Applied at build time; not adjustable at runtime.
	  65535 = full 16-bit range.

config VC_DEFAULT_OUTPUT_CAL_K
	int "Default output calibration gain (×10⁻⁴, unit: 1/(100 mV))"
	default 32768
	range 1 65535
	help
	  Factory default for output_calib_k. The DAC drive formula is
	  raw = (target × k) / 10000 + b. At k=32768 a target of 20000 (2000 V)
	  maps to DAC code 65536, filling the full 16-bit range.

config VC_DEFAULT_MEASURED_V_CAL_K
	int "Default measured-voltage calibration gain (×10⁻⁶, unit: 1/(100 mV))"
	default 1
	range 1 65535
	help
	  Factory default for measured_voltage_calib_k, applied before a real
	  per-unit calibration is loaded. The gain is raw_adc * k / 1000000,
	  so the maximum representable gain is 65535/1000000 (~0.0655) and
	  unity (1.0×) is not representable — this field only ever scales
	  down an attenuated raw ADC reading, never passes it through
	  unchanged. The default of 1 yields an intentionally negligible
	  reading until the board is calibrated.

config VC_DEFAULT_MEASURED_I_CAL_K
	int "Default measured-current calibration gain (×10⁻⁶, unit: 1/(10000 nA))"
	default 1
	range 1 65535
	help
	  Factory default for measured_current_calib_k, applied before a real
	  per-unit calibration is loaded. The gain is raw_adc * k / 1000000,
	  so the maximum representable gain is 65535/1000000 (~0.0655) and
	  unity (1.0×) is not representable — this field only ever scales
	  down an attenuated raw ADC reading, never passes it through
	  unchanged. The default of 1 yields an intentionally negligible
	  reading until the board is calibrated.

config VC_MAX_TARGET_VOLTAGE
	int "Maximum configurable target voltage (×100 mV)"
	default 20000
	range 1 32767
	help
	  Upper bound accepted for the per-channel configured_target_voltage field
	  in normal and automatic modes. Unit is ×100 mV (e.g. 20000 = 2000 V).
	  The field is signed 16-bit so 32767 is the absolute type ceiling.

config VC_DEFAULT_CURRENT_LIMIT
	int "Default current limit threshold (raw, x0.1 nA/LSB)"
	default 10000
	range 1 32767
	help
	  Factory default for the per-channel current_limit_threshold field.
	  Unit is x0.1 nA per LSB, the same convention as measured_current
	  (see docs/guide/parameter-reference.md). Default 10000 = 1000 nA
	  (1 uA). The field is signed 16-bit, so 32767 (3276.7 nA) is the
	  absolute ceiling.

config VC_DEFAULT_RAMP_STEP
	int "Default output ramp step size"
	default 150
	range 1 65535
	help
	  Factory default for ramp_up_step and ramp_down_step. Unit matches the
	  configured_target_voltage field (×100 mV per ramp interval).

config VC_DEFAULT_CURRENT_SAFE_BAND_PCT
	int "Default current safe-band percentage"
	default 10
	range 0 100
	help
	  Factory default for current_safe_band_pct. Current protection is
	  suppressed while the output is within this percentage of the limit,
	  to avoid false trips during normal transients.

config VC_CAL_WATCHDOG_TIMEOUT_S
	int "VC calibration inactivity watchdog timeout"
	default 300
	range 1 3600
	help
	  Time in seconds before inactive calibration mode automatically exits.

config VC_SETTINGS_PERSISTENCE
	bool "VC settings persistence via NVS"
	depends on VC_RUNTIME
	select SETTINGS
	select NVS
	select FLASH
	select FLASH_MAP
	help
	  Enable save/load/factory-reset of system and channel configs
	  using Zephyr Settings backed by NVS on internal flash.

config VC_SHELL
	bool "Zephyr shell adapter for voltage-control"
	default n
	depends on VC_RUNTIME
	select SHELL
	select SHELL_BACKEND_SERIAL
	help
	  Enable interactive shell commands under the "vc" top-level
	  command for controlling and monitoring the voltage-control
	  system.

if VC_SHELL

config VC_SHELL_WATCH_DEFAULT_INTERVAL_MS
	int "Default watch interval (ms)"
	default 1000
	range 100 10000
	help
	  Default polling interval in milliseconds for the vc watch command.

endif # VC_SHELL
