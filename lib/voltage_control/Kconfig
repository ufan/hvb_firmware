config VC_CHANNEL_PROVIDER
	bool "VC channel provider support"
	help
	  Enable the virtual voltage channel provider subsystem.
	  Selected by concrete provider drivers when DTS nodes exist.

config VC_CHANNEL_CONTROLLER
	bool "VC channel controller aggregation"
	default y
	depends on DT_HAS_JIANWEI_VC_CONTROLLER_ENABLED
	select VC_CHANNEL_PROVIDER
	help
	  Enable compile-time channel table aggregation from the
	  vc-controller DTS node.

config VC_RUNTIME
	bool "VC runtime service"
	help
	  Enable the voltage-control runtime service.

config VC_RUNTIME_COMMAND_QUEUE_DEPTH
	int "VC runtime command queue depth"
	default 8
	range 1 64
	depends on VC_RUNTIME
	help
	  Maximum number of queued runtime commands.

config VC_RUNTIME_EVIDENCE_QUEUE_DEPTH
	int "VC runtime evidence queue depth"
	default 4
	range 1 64
	depends on VC_RUNTIME
	help
	  Maximum number of queued runtime evidence records.
