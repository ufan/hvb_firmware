config SYS_RESET
	bool "System reset service"
	depends on REBOOT
	default n
	help
	  Provide a delayed system-level cold-reset request service.

config SYS_RESET_DELAY_MS
	int "System reset response-drain delay (ms)"
	depends on SYS_RESET
	default 250
	range 1 5000
	help
	  Delay before rebooting so the requesting frontend can finish its
	  response.

config SYS_STATUS
	bool "System status module (heartbeat, environment sensor)"
	default n
	help
	  Self-contained module: SYS_RUN heartbeat LED, SHT3x temp/humidity.
	  Initialized via SYS_INIT, runs its own thread. Uptime and firmware
	  version have no hardware dependency and are always available
	  regardless of this option — see sys_uptime.c.

if SYS_STATUS

config SYS_STATUS_HEARTBEAT_INTERVAL_MS
	int "Heartbeat LED toggle interval (ms)"
	default 500
	range 100 5000
	help
	  Interval in milliseconds between SYS_RUN LED toggles.

config SYS_STATUS_SENSOR_INTERVAL_MS
	int "Temperature/humidity sensor poll interval (ms)"
	default 1000
	range 500 60000
	help
	  Interval in milliseconds between SHT3x sensor reads.

config SYS_STATUS_THREAD_STACK_SIZE
	int "sys_status thread stack size"
	default 1024
	range 512 4096
	help
	  Stack size in bytes for the sys_status worker thread.

config SYS_STATUS_THREAD_PRIORITY
	int "sys_status thread priority"
	default 7
	range 1 15
	help
	  Zephyr thread priority for the sys_status worker.

endif # SYS_STATUS

config SYS_STATUS_SHELL
	bool "Shell commands for system status"
	default n
	select SHELL
	help
	  Enable "ss" shell command to display uptime and firmware version.
	  Also shows board temperature/humidity when CONFIG_SYS_STATUS is
	  enabled. Does not depend on CONFIG_SYS_STATUS itself.
