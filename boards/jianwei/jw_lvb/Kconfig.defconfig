if BOARD_JW_LVB

config BOARD
	default "jw_lvb"

config LVB_VC_CHANNEL
	default y

config VC_VARIANT_ID
	default 2

# LVB channels drive real loads at amp scale, not the nA-scale sense currents
# jw_hvb measures — the default 0.1nA/LSB unit can only represent up to
# 3.2768uA in an int16, nowhere near enough. 1mA/LSB (+-32.767A range) fits
# this board's real currents (a few amps at most) with much finer
# resolution than the coarser 0.1A/LSB (100mA/LSB) this used to default to.
config VC_CURRENT_UNIT_EXP
	default -3

# All 10 channels are fixed-voltage (no DAC); the reference firmware drives
# every channel active at boot, individually switchable afterward except
# channel 1 (locked always-on, see jw_lvb.dts vc_ch0's capabilities).
config VC_DEFAULT_OUTPUT_ENABLED
	default y

# Needed for the above to take effect at boot: the AUTOMATIC-mode invariant
# (which honors VC_DEFAULT_OUTPUT_ENABLED for fixed-voltage channels) only
# runs on a detected mode transition, so the board must default into
# AUTOMATIC rather than NORMAL.
config VC_DEFAULT_OPERATING_MODE
	default 1

# Voltage sampling note in the schematic marks the channel divider/isolated
# amplifier path as IN 12V -> OUT 2.14V. With a 12-bit STM32 ADC referenced to
# VDDA ~= 3.3V, 2.14V is ~2656 counts. The voltage register unit is fixed at
# 0.1V/LSB, so 12V must report 120 LSB: 120/2656 = 0.045177 LSB/count.
# Real per-unit calibration supersedes this factory nominal once run.
config VC_DEFAULT_MEASURED_V_CAL_K
	default 45177

config VC_DEFAULT_MEASURED_V_CAL_K_EXP
	default -6

# Current measurement uses ACS712-20A sensitivity (100mV/A), then the
# schematic's equal 20K/20K R3/R2 network halves the signal before the
# RS8412XK buffer. Effective ADC sensitivity is therefore ~50mV/A. One ADC
# count is 3.3V/4096 = 0.8057mV, so one amp is ~62.06 counts. With
# VC_CURRENT_UNIT_EXP=-3 (1mA/LSB), the register gain is
# 1000/62.06 = 16.113 LSB/count — same mantissa as the old 0.1A/LSB gain
# (0.16113 LSB/count), just moved two decades by K_EXP since only the
# *declared* register unit changed, not the physical ADC calibration.
config VC_DEFAULT_MEASURED_I_CAL_K
	default 16113

config VC_DEFAULT_MEASURED_I_CAL_K_EXP
	default -3

# At the register gain above (16.113 mA/LSB), even modest ADC jitter reads
# out as a large current swing — the generic driver default of 5 samples
# (150ms report period) let no-load current jump by several hundred mA
# between reports. 16 samples (~480ms) helped but some channels still
# showed report-to-report stdev up to ~160mA on real hardware.
#
# Oversampling noise falls off as 1/sqrt(N), so from a measured N=16
# baseline (stdev per channel 21-159mA across 10 channels) the expected
# stdev at other N is baseline x sqrt(16/N). Budgeting a <2s report
# period caps N at ~66 (66 x 30ms sample tick = 1980ms); N=64 lands just
# under that with margin (1920ms) and roughly halves the N=16 noise
# (predicted 10-80mA range) — worth it since AUTOMATIC-mode protection
# response time isn't documented as needing to be faster than ~2s on
# this board. Confirm the halving actually held on real hardware before
# trusting this comment; the 1/sqrt(N) model assumes i.i.d. sample
# noise, which is an approximation, not a guarantee.
config LVB_VC_OVERSAMPLE_COUNT
	default 64

# The generic VC_DEFAULT_CURRENT_LIMIT default (10000) is sized for
# jw_hvb's nA-scale unit — reused as-is on jw_lvb's 1 mA/LSB unit it would
# mean 10000 mA (10 A), not a sane per-channel limit for this board's real
# loads. 6000 = 6000 mA (6 A).
config VC_DEFAULT_CURRENT_LIMIT
	default 6000

endif # BOARD_JW_LVB
