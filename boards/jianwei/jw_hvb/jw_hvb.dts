/dts-v1/;

#include <st/f4/stm32f429Xi.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/pinctrl/stm32-pinctrl.h>

/ {
	model = "Jianwei High Voltage Board";
	compatible = "jianwei,jw-hvb";

	chosen {
		zephyr,console = &usart3;
		zephyr,shell-uart = &usart3;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	aliases {
		led0 = &sys_run;
	};

	leds {
		compatible = "gpio-leds";

		sys_run: sys_run {
			gpios = <&gpioi 12 GPIO_ACTIVE_HIGH>;
			label = "SYS_RUN";
		};
	};
};

&clk_hse {
	clock-frequency = <DT_FREQ_M(8)>;
	status = "okay";
};

&pll {
	div-m = <8>;
	mul-n = <336>;
	div-p = <2>;
	div-q = <7>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(168)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <4>;
	apb2-prescaler = <2>;
};

&gpiog {
	status = "okay";
};

&gpioi {
	status = "okay";
};

&usart3 {
	/*
	 * The debug header nets are named USART1_TX/RX in the schematic, but
	 * PC10/PC11 map to USART3_TX/RX on STM32F429.
	 */
	pinctrl-0 = <&usart3_tx_pc10 &usart3_rx_pc11>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
	pinctrl-names = "default";
	clock-frequency = <I2C_BITRATE_STANDARD>;
	status = "okay";

	sht3xd_44: sht3xd@44 {
		compatible = "sensirion,sht3xd";
		reg = <0x44>;
	};
};

&usart6 {
	pinctrl-0 = <&usart6_tx_pg14 &usart6_rx_pg9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";

	modbus0 {
		compatible = "zephyr,modbus-serial";
		status = "okay";
		de-gpios = <&gpiog 11 GPIO_ACTIVE_HIGH>;
	};
};

&pinctrl {
	usart3_tx_pc10: usart3_tx_pc10 {
		pinmux = <STM32_PINMUX('C', 10, AF7)>;
	};

	usart3_rx_pc11: usart3_rx_pc11 {
		pinmux = <STM32_PINMUX('C', 11, AF7)>;
		bias-pull-up;
	};

	usart6_tx_pg14: usart6_tx_pg14 {
		pinmux = <STM32_PINMUX('G', 14, AF8)>;
	};

	usart6_rx_pg9: usart6_rx_pg9 {
		pinmux = <STM32_PINMUX('G', 9, AF8)>;
		bias-pull-up;
	};

	i2c1_scl_pb8: i2c1_scl_pb8 {
		pinmux = <STM32_PINMUX('B', 8, AF4)>;
	};

	i2c1_sda_pb9: i2c1_sda_pb9 {
		pinmux = <STM32_PINMUX('B', 9, AF4)>;
	};
};
