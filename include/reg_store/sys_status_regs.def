/* name, semantic field, type, access, category */
SYS_STATUS_REG(BOARD_TEMPERATURE, 0x0001, S16, RO, MEASUREMENT_RAW)
SYS_STATUS_REG(BOARD_HUMIDITY,    0x0002, U16, RO, MEASUREMENT_RAW)
SYS_STATUS_REG(UPTIME,            0x0003, U32, RO, RUNTIME_STATE)
SYS_STATUS_REG(FW_VERSION,        0x0004, U32, RO, FIXED)
SYS_STATUS_REG(RESET,             0x0201, U16, WO, COMMAND)
