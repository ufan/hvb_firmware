/*
 * Modbus wire-address view for Jianwei voltage-control protocol v3.
 * Consumed via X-macro inclusion from reg_map.h with caller-defined
 * MODBUS_SYS16/MODBUS_SYS32/MODBUS_VC16/MODBUS_VC32 macros.
 *
 * OFFSET ALLOCATION RULES:
 *   - 32-bit registers claim offset N and N+1 — both are shown inline.
 *     Never place any other register at N+1.
 *   - Gaps marked "reserved" are protocol-fixed. Do not fill them;
 *     they are held for future minor-version additions.
 *   - Existing offsets are never reassigned. Additions go to the
 *     highest free slot in the relevant block and must not disturb
 *     prior entries.
 *
 * Banks: INPUT   = FC04 (read-only status and measurement)
 *        HOLDING = FC03/FC06 (read-write config and commands)
 *
 * Poll categories (4th field):
 *   REALTIME  live measurements, status, faults — poll fast (~100 ms)
 *   CONFIG    operational parameters — poll slow or on demand
 *   FIXED     version, variant, capabilities — read once at connect
 *   COMMAND   write-only triggers — do not poll
 */

/* ---- System input (FC04, offsets 0..14; 15..39 reserved) ----------- */
MODBUS_SYS16(PROTOCOL_MAJOR,         INPUT,   0, FIXED)
MODBUS_SYS16(PROTOCOL_MINOR,         INPUT,   1, FIXED)
MODBUS_SYS16(VARIANT_ID,             INPUT,   2, FIXED)
MODBUS_SYS16(CAPABILITY_FLAGS,       INPUT,   3, FIXED)
MODBUS_SYS16(SUPPORTED_CHANNELS,     INPUT,   4, FIXED)
MODBUS_SYS16(ACTIVE_CHANNEL_MASK,    INPUT,   5, REALTIME)
MODBUS_SYS16(BOARD_TEMPERATURE,      INPUT,   6, REALTIME)
MODBUS_SYS16(BOARD_HUMIDITY,         INPUT,   7, REALTIME)
MODBUS_SYS32(UPTIME,                 INPUT,   8, REALTIME) /* spans 8..9 */
MODBUS_SYS32(FW_VERSION,             INPUT,  10, FIXED)    /* spans 10..11 */
MODBUS_SYS16(ACTIVE_OPERATING_MODE,  INPUT,  12, REALTIME)
MODBUS_SYS16(STATUS,                 INPUT,  13, REALTIME)
MODBUS_SYS16(FAULT_CAUSE,            INPUT,  14, REALTIME)
/* 15..39 reserved */

/* ---- System holding (FC03/FC06, offsets 0..3; 4..38 reserved) ------ */
MODBUS_SYS16(OPERATING_MODE,         HOLDING,  0, CONFIG)
MODBUS_SYS16(STARTUP_CHANNEL_POLICY, HOLDING,  1, CONFIG)
MODBUS_SYS16(SLAVE_ADDRESS,          HOLDING,  2, CONFIG)
MODBUS_SYS16(BAUD_RATE_CODE,         HOLDING,  3, CONFIG)
/* 4..38 reserved */
MODBUS_SYS16(PARAM_ACTION,           HOLDING, 39, COMMAND) /* v2 wire address preserved for compatibility */

/* ---- Channel input (FC04, offsets 0..15; 16..39 reserved) ---------- */
MODBUS_VC16(STATUS_BITS,             INPUT,  0,  REALTIME)
MODBUS_VC16(ACTIVE_FAULT_CAUSE,      INPUT,  1,  REALTIME)
MODBUS_VC16(FAULT_HISTORY_CAUSE,     INPUT,  2,  REALTIME)
MODBUS_VC16(LAST_PROT_OUT_ACTION,    INPUT,  3,  REALTIME)
MODBUS_VC16(AUTO_RETRY_COUNT,        INPUT,  4,  REALTIME)
MODBUS_VC16(AUTO_COOLDOWN_REMAINING, INPUT,  5,  REALTIME)
MODBUS_VC32(LAST_FAULT_TIMESTAMP,    INPUT,  6,  REALTIME) /* spans 6..7 */
MODBUS_VC16(OPER_TARGET_VOLTAGE,     INPUT,  8,  REALTIME)
MODBUS_VC16(CAPABILITY_FLAGS,        INPUT,  9,  FIXED)
MODBUS_VC16(MEASURED_VOLTAGE,        INPUT,  10, REALTIME)
MODBUS_VC16(MEASURED_CURRENT,        INPUT,  11, REALTIME)
MODBUS_VC32(RAW_ADC_VOLTAGE,         INPUT,  12, REALTIME) /* spans 12..13 */
MODBUS_VC32(RAW_ADC_CURRENT,         INPUT,  14, REALTIME) /* spans 14..15 */
/* 16..39 reserved */

/* ---- Channel holding (FC03/FC06) ----------------------------------- */
/* Commands / output control (offsets 0..2) */
MODBUS_VC16(OUTPUT_ACTION,           HOLDING,  0, COMMAND)
MODBUS_VC16(FAULT_CMD,               HOLDING,  1, COMMAND)
MODBUS_VC16(PARAM_ACTION,            HOLDING,  2, COMMAND)
/* Operational config (offsets 3..16) */
MODBUS_VC16(CFG_TARGET_VOLTAGE,      HOLDING,  3, CONFIG)
MODBUS_VC16(RAMP_UP_STEP,            HOLDING,  4, CONFIG)
MODBUS_VC16(RAMP_UP_INTERVAL,        HOLDING,  5, CONFIG)
MODBUS_VC16(RAMP_DOWN_STEP,          HOLDING,  6, CONFIG)
MODBUS_VC16(RAMP_DOWN_INTERVAL,      HOLDING,  7, CONFIG)
MODBUS_VC16(RECOVERY_POLICY_MODE,    HOLDING,  8, CONFIG)
MODBUS_VC16(AUTO_RETRY_DELAY,        HOLDING,  9, CONFIG)
MODBUS_VC16(AUTO_RETRY_MAX_COUNT,    HOLDING, 10, CONFIG)
MODBUS_VC16(AUTO_RETRY_WINDOW,       HOLDING, 11, CONFIG)
MODBUS_VC16(CURRENT_SAFE_BAND_PCT,   HOLDING, 12, CONFIG)
MODBUS_VC16(CURRENT_PROTECTION_MODE, HOLDING, 13, CONFIG)
MODBUS_VC16(CURRENT_PROT_OUT_ACTION, HOLDING, 14, CONFIG)
MODBUS_VC16(CURRENT_LIMIT_THRESHOLD, HOLDING, 15, CONFIG)
MODBUS_VC16(AUTO_DERATE_STEP,        HOLDING, 16, CONFIG)
/* 17..19 reserved for future channel config fields */
/* Calibration coefficients (offsets 20..25) */
MODBUS_VC16(OUTPUT_CAL_K,            HOLDING, 20, CONFIG)
MODBUS_VC16(OUTPUT_CAL_B,            HOLDING, 21, CONFIG)
MODBUS_VC16(MEASURED_V_CAL_K,        HOLDING, 22, CONFIG)
MODBUS_VC16(MEASURED_V_CAL_B,        HOLDING, 23, CONFIG)
MODBUS_VC16(MEASURED_I_CAL_K,        HOLDING, 24, CONFIG)
MODBUS_VC16(MEASURED_I_CAL_B,        HOLDING, 25, CONFIG)
/* 26..29 reserved for future calibration coefficient fields */
/* Calibration session commands (offsets 30..34) */
MODBUS_VC16(CAL_OUTPUT_ENABLE,       HOLDING, 30, COMMAND)
MODBUS_VC16(CAL_DAC_CODE,            HOLDING, 31, COMMAND)
MODBUS_VC16(CAL_SAMPLE_CMD,          HOLDING, 32, COMMAND)
MODBUS_VC16(CAL_COMMIT_CMD,          HOLDING, 33, COMMAND)
/* 34..39 reserved for future calibration command fields */
