/* name, semantic field, type, access, category, Modbus bank, first offset */
SYS_REG16(PROTOCOL_MAJOR,          0x0001, U16,  RO, FIXED,         INPUT,    0)
SYS_REG16(PROTOCOL_MINOR,          0x0002, U16,  RO, FIXED,         INPUT,    1)
SYS_REG16(VARIANT_ID,              0x0003, U16,  RO, FIXED,         INPUT,    2)
SYS_REG16(CAPABILITY_FLAGS,        0x0004, U16,  RO, FIXED,         INPUT,    3)
SYS_REG16(SUPPORTED_CHANNELS,      0x0005, U16,  RO, FIXED,         INPUT,    4)
SYS_REG16(ACTIVE_CHANNEL_MASK,     0x0006, U16,  RO, FIXED,         INPUT,    5)
SYS_REG16(BOARD_TEMPERATURE,       0x0007, S16,  RO, MEASUREMENT_RAW, INPUT,    6)
SYS_REG16(BOARD_HUMIDITY,          0x0008, U16,  RO, MEASUREMENT_RAW, INPUT,    7)
SYS_REG32(UPTIME,                  0x0009, U32,  RO, RUNTIME_STATE, INPUT,    8)
SYS_REG32(FW_VERSION,              0x000a, U32,  RO, FIXED,         INPUT,   10)
SYS_REG16(ACTIVE_OPERATING_MODE,   0x000b, ENUM, RO, RUNTIME_STATE, INPUT,   12)
SYS_REG16(STATUS,                  0x000c, U16,  RO, RUNTIME_STATE, INPUT,   13)
SYS_REG16(FAULT_CAUSE,             0x000d, U16,  RO, RUNTIME_STATE, INPUT,   14)
SYS_REG16(OPERATING_MODE,          0x0101, ENUM, RW, CONFIG,        HOLDING,  0)
SYS_REG16(STARTUP_CHANNEL_POLICY,  0x0102, U16,  RW, CONFIG,        HOLDING,  1)
SYS_REG16(SLAVE_ADDRESS,           0x0103, U16,  RW, CONFIG,        HOLDING,  2)
SYS_REG16(BAUD_RATE_CODE,          0x0104, U16,  RW, CONFIG,        HOLDING,  3)
SYS_REG16(PARAM_ACTION,            0x0201, U16,  WO, COMMAND,       HOLDING, 39)
