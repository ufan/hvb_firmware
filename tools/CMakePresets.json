{
  "version": 3,
  "configurePresets": [
    {
      "name": "linux-debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_GUI": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "linux-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GUI": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "linux-gui",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-gui",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GUI": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "win-release",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/windows-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GUI": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "mingw-release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/mingw-release",
      "toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_GUI": "OFF",
        "BUILD_SHARED_LIBS": "OFF",
        "BUILD_FACTORY": "ON"
      }
    }
  ]
}
